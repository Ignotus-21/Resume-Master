PORT=5000
MONGO_URI=mongodb://admin:changeme@localhost:27017/master_resume?authSource=admin
GEMINI_API_KEY=API KEY HERE
CORS_ORIGIN=http://localhost:3000

# Used by docker-compose.yml for the local MongoDB container
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=changeme

# Auth
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change-me-to-a-32-byte-hex-string

# Optional: enables "Continue with Google" sign-in. Leave unset to disable it
# (email/password auth still works standalone). Create credentials at
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# Shared Gemini key free-tier quota (per account/guest session)
SHARED_GEMINI_RATE_LIMIT=15
SHARED_GEMINI_RATE_WINDOW_HOURS=4

# Set to "production" to require Secure cookies (HTTPS)
NODE_ENV=development

# Number of reverse-proxy hops in front of the app (for correct client IP in
# rate limiting and the guest AI-quota key). Leave 0 when NOT behind a proxy
# (prevents X-Forwarded-For spoofing); set to 1 for a single trusted proxy.
TRUST_PROXY_HOPS=0

# Public URL of the frontend, used to build links in verification/reset emails.
APP_URL=http://localhost:3000

# Transactional email (Resend). If unset, emails are logged to the server
# console instead of sent — fine for local dev. https://resend.com
RESEND_API_KEY=
EMAIL_FROM=Resume Master <onboarding@resend.dev>

# Cloudflare Turnstile CAPTCHA on signup. If TURNSTILE_SECRET_KEY is unset the
# CAPTCHA check is skipped. https://developers.cloudflare.com/turnstile
TURNSTILE_SECRET_KEY=

# Set to "true" when the frontend and backend are on DIFFERENT domains (e.g.
# Vercel frontend + Railway backend) so the auth cookie is SameSite=None; Secure.
# Requires HTTPS on both. Leave unset/false for same-site local dev.
COOKIE_SAMESITE_NONE=false
