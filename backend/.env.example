PORT=5000
MONGO_URI=mongodb://admin:changeme@localhost:27017/master_resume?authSource=admin
GEMINI_API_KEY=API KEY HERE
# Optional: override the Gemini model id without a code change/redeploy.
# Defaults to gemini-2.5-flash if unset.
GEMINI_MODEL=
CORS_ORIGIN=http://localhost:3000

# Used by docker-compose.yml for the local MongoDB container
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=changeme

# Auth
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=change-me-to-a-long-random-string
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=change-me-to-a-32-byte-hex-string

# Optional: enables "Continue with Google" sign-in. Leave unset to disable it
# (email/password auth still works standalone). Create credentials at
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=

# Shared Gemini key free-tier quota for guests, per SHARED_GEMINI_RATE_WINDOW_HOURS
# (registered users' limits are configured in AppConfig via the admin dashboard).
SHARED_GEMINI_RATE_WINDOW_HOURS=6

# Set to "production" to require Secure cookies (HTTPS)
NODE_ENV=development

# Number of reverse-proxy hops in front of the app (for correct client IP in
# rate limiting and the guest AI-quota key). Leave 0 when NOT behind a proxy
# (prevents X-Forwarded-For spoofing); set to 1 for a single trusted proxy,
# 2 when requests also flow through the frontend's /api proxy (client →
# Vercel → backend host).
TRUST_PROXY_HOPS=0

# Public URL of the frontend, used to build links in verification/reset emails.
APP_URL=http://localhost:3000

# Transactional email (Resend). If unset, emails are logged to the server
# console instead of sent — fine for local dev. https://resend.com
RESEND_API_KEY=
EMAIL_FROM="Resume Master <onboarding@resend.dev>"

# Cloudflare Turnstile CAPTCHA on signup. If TURNSTILE_SECRET_KEY is unset the
# CAPTCHA check is skipped. https://developers.cloudflare.com/turnstile
TURNSTILE_SECRET_KEY=

# Optional Redis for rate limiting (persists across restarts, shared across
# instances). An Upstash free-tier rediss:// URL works. Unset = in-memory.
REDIS_URL=

# Only needed when the browser calls the backend cross-domain directly
# (NEXT_PUBLIC_API_URL set to the backend URL) so the auth cookie can be
# SameSite=None; Secure — requires HTTPS on both sides. NOT needed with the
# recommended same-origin /api proxy in frontend/next.config.ts, which keeps
# the cookie SameSite=Lax.
COOKIE_SAMESITE_NONE=false
