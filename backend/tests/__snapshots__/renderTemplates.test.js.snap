\\newcommand{\\resumeSubHeadingListEnd}{\\end{itemize}}
\\newcommand{\\resumeItemListStart}{\\begin{itemize}[label=\\textbullet, itemsep=2pt]}
\\newcommand{\\resumeItemListEnd}{\\end{itemize}\\vspace{-5pt}}

\\begin{document}

\\begin{center}
    \\textbf{\\Huge \\scshape Ada Lovelace} \\\\ \\vspace{4pt}
    \\small +1 555 010 0101 $|$ \\href{mailto:ada@example.com}{ada@example.com} $|$ \\href{https://linkedin.com/in/ada}{linkedin.com/in/ada} $|$ \\href{https://github.com/ada}{github.com/ada} $|$ \\href{https://ada.dev}{ada.dev} $|$ London, UK
\\end{center}

\\section{Experience}
  \\resumeSubHeadingListStart
    \\resumeSubheading{Senior Software Engineer}{Jan 2022 -- Present}{Analytical Engines Ltd}{Remote}
      \\resumeItemListStart
        \\resumeItem{Led migration of a monolith to services, cutting deploy time by 80\\%}
        \\resumeItem{Mentored 4 engineers; introduced code review practices}
      \\resumeItemListEnd
    \\resumeSubheading{Software Engineer}{Mar 2019 -- Dec 2021}{Babbage \\& Co}{London}
      \\resumeItemListStart
        \\resumeItem{Built the first compiler}
      \\resumeItemListEnd
