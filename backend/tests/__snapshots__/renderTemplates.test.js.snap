"\\documentclass[letterpaper,11pt]{article}
\\usepackage{ebgaramond}
\\usepackage[margin=0.7in]{geometry}
\\usepackage{setspace}
\\setstretch{1}
\\usepackage{titlesec}
\\usepackage{enumitem}
