    \\resumeSubheading{Mentor}{2020 -- 2022}{Code Club}{}
      \\resumeItemListStart
        \\resumeItem{Taught kids to code.}
      \\resumeItemListEnd
  \\resumeSubHeadingListEnd

\\section{Patents}
  \\resumeSubHeadingListStart
    \\resumeProjectHeading{\\textbf{Loom control mechanism} $|$ GB-0001}{1842}
      \\resumeItemListStart
        \\resumeItem{Punch card sequencing.}
      \\resumeItemListEnd
  \\resumeSubHeadingListEnd

\\section{Interests}
 \\begin{itemize}[leftmargin=0.15in, label={}]
    \\small{\\item{Chess, Horse racing}}
 \\end{itemize}

\\section{Leadership}
  \\resumeSubHeadingListStart
    \\resumeProjectHeading{\\textbf{Chair} $|$ \\emph{Royal Society computing group}}{1841}
      \\resumeItemListStart
        \\resumeItem{Organized monthly colloquia.}
        \\resumeItem{Grew membership 3x}
