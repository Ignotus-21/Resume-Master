\\titleformat{\\section}{\\normalsize\\bfseries}{}{0em}{}[\\color{accent}\\titlerule]
\\titlespacing*{\\section}{0pt}{8pt}{4pt}
\\setlist[itemize]{leftmargin=0.18in, itemsep=2pt, parsep=0pt, topsep=2pt, label=\\textbullet}
\\begin{document}
\\begin{center}
{\\Large\\bfseries Ada Lovelace}\\\\[4pt]
{\\small +1 555 010 0101 $|$ \\href{mailto:ada@example.com}{ada@example.com} $|$ \\href{https://linkedin.com/in/ada}{linkedin.com/in/ada} $|$ \\href{https://github.com/ada}{github.com/ada} $|$ \\href{https://ada.dev}{ada.dev} $|$ London, UK}
\\end{center}

\\section{\\MakeUppercase{Experience}}
\\textbf{Senior Software Engineer} \\hfill Jan 2022 -- Present\\\\
\\textit{Analytical Engines Ltd} \\hfill Remote\\\\
\\begin{itemize}
  \\item Led migration of a monolith to services, cutting deploy time by 80\\%
  \\item Mentored 4 engineers; introduced code review practices
\\end{itemize}
\\vspace{4pt}

\\textbf{Software Engineer} \\hfill Mar 2019 -- Dec 2021\\\\
\\textit{Babbage \\& Co} \\hfill London\\\\
\\begin{itemize}
  \\item Built the first compiler
\\end{itemize}

\\section{\\MakeUppercase{Education}}
\\textbf{University of London} \\hfill 2015 -- 2019\\\\
BSc in Mathematics --- GPA: 3.9/4.0\\\\
\\textit{Coursework:} Number Theory, Mechanics\\\\

\\section{\\MakeUppercase{Projects}}
\\textbf{Difference Engine} (\\href{https://github.com/ada/difference-engine}{link}) \\hfill \\textit{Brass, Steam}\\\\
A mechanical calculator for polynomial functions.\\\\
\\begin{itemize}
  \\item Computed tables to 31 digits
\\end{itemize}

\\section{\\MakeUppercase{Technical Skills}}
\\textbf{Languages:} Ada, Python, TypeScript\\\\
\\textbf{Frameworks:} React, Express\\\\
\\textbf{Tools:} Git, Docker\\\\
\\textbf{Other:} Distributed systems\\\\

\\section{\\MakeUppercase{Certifications}}
\\textbf{AWS Solutions Architect} --- Amazon \\hfill Jun 2023\\\\

\\section{\\MakeUppercase{Achievements}}
\\textbf{First programmer} \\hfill 1843\\\\
Wrote the first algorithm.\\\\

\\section{\\MakeUppercase{Publications}}
\\textbf{Notes on the Analytical Engine} \\hfill 1843\\\\
Sketch of the engine.\\\\

\\section{\\MakeUppercase{Volunteering}}
\\textbf{Mentor}, Code Club \\hfill 2020 -- 2022\\\\
Taught kids to code.\\\\

\\section{\\MakeUppercase{Patents}}
\\textbf{Loom control mechanism} (GB-0001) \\hfill 1842\\\\
Punch card sequencing.\\\\

\\section{\\MakeUppercase{Interests}}
Chess, Horse racing\\\\

\\section{\\MakeUppercase{Leadership}}
\\textbf{Chair} --- Royal Society computing group \\hfill 1841\\\\
Organized monthly colloquia.\\\\
\\begin{itemize}
  \\item Grew membership 3x
\\end{itemize}
\\end{document}
"
`;

