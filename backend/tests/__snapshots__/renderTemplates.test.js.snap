    \\resumeSubheading{University of London}{2015 -- 2019}{BSc in Mathematics --- GPA: 3.9/4.0}{}
      \\resumeItemListStart
        \\resumeItem{Relevant Coursework: Number Theory, Mechanics}
      \\resumeItemListEnd
  \\resumeSubHeadingListEnd

\\section{Projects}
  \\resumeSubHeadingListStart
    \\resumeProjectHeading{\\textbf{Difference Engine} $|$ \\href{https://github.com/ada/difference-engine}{link} $|$ \\emph{Brass, Steam}}{}
      \\resumeItemListStart
        \\resumeItem{A mechanical calculator for polynomial functions.}
        \\resumeItem{Computed tables to 31 digits}
      \\resumeItemListEnd
  \\resumeSubHeadingListEnd

\\section{Technical Skills}
 \\begin{itemize}[leftmargin=0.15in, label={}]
    \\small{\\item{
     \\textbf{Languages}{: Ada, Python, TypeScript} \\\\
     \\textbf{Frameworks}{: React, Express} \\\\
     \\textbf{Tools}{: Git, Docker} \\\\
     \\textbf{Other}{: Distributed systems} \\\\
    }}
 \\end{itemize}

\\section{Certifications}
  \\resumeSubHeadingListStart
    \\resumeProjectHeading{\\textbf{AWS Solutions Architect} $|$ \\emph{Amazon}}{Jun 2023}
  \\resumeSubHeadingListEnd

\\section{Achievements}
  \\resumeSubHeadingListStart
    \\resumeProjectHeading{\\textbf{First programmer}}{1843}
      \\resumeItemListStart
        \\resumeItem{Wrote the first algorithm.}
      \\resumeItemListEnd
  \\resumeSubHeadingListEnd

\\section{Publications}
  \\resumeSubHeadingListStart
    \\resumeProjectHeading{\\textbf{Notes on the Analytical Engine}}{1843}
      \\resumeItemListStart
        \\resumeItem{Sketch of the engine.}
      \\resumeItemListEnd
  \\resumeSubHeadingListEnd

\\section{Volunteering}
