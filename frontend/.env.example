NEXT_PUBLIC_API_URL=http://localhost:5000

# Optional: enables the "Continue with Google" button on /login and /signup.
# Leave unset to hide it — email/password auth works standalone.
# Must match the backend's GOOGLE_CLIENT_ID.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional: Cloudflare Turnstile CAPTCHA on signup. Leave unset to hide it.
# The matching secret goes in the backend's TURNSTILE_SECRET_KEY.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
