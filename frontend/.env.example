# Leave empty (recommended): API calls go to /api/* on this origin and Next.js
# proxies them to the backend (see next.config.ts). Set BACKEND_URL instead to
# point the proxy at a deployed backend. Only set NEXT_PUBLIC_API_URL to call a
# backend directly cross-origin (requires COOKIE_SAMESITE_NONE on the backend).
NEXT_PUBLIC_API_URL=

# Backend the /api/* rewrite proxies to. Defaults to http://localhost:5000.
BACKEND_URL=

# Optional: enables the "Continue with Google" button on /login and /signup.
# Leave unset to hide it — email/password auth works standalone.
# Must match the backend's GOOGLE_CLIENT_ID.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Optional: Cloudflare Turnstile CAPTCHA on signup. Leave unset to hide it.
# The matching secret goes in the backend's TURNSTILE_SECRET_KEY.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
